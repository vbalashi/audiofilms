{
  "manifest_version": 3,
  "name": "AudioFilms YouTube Shadowing",
  "version": "0.1.0",
  "description": "Phrase-by-phrase shadowing controls for YouTube captions.",
  "key": "",
  "action": {
    "default_title": "Toggle AudioFilms on YouTube"
  },
  "permissions": [
    "identity",
    "storage"
  ],
  "options_page": "src/options.html",
  "background": {
    "service_worker": "src/serviceWorker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*"
      ],
      "js": [
        "src/pageBridge.js"
      ],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*"
      ],
      "js": [
        "src/config.js",
        "src/bootDiagnostics.js",
        "src/phrases.js",
        "src/captionTracks.js",
        "src/youtubeAdapter.js",
        "src/transcriptRetrieval.js",
        "src/sourceBinding.js",
        "src/dictionaryActions.js",
        "src/content.js"
      ],
      "css": [
        "src/content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "https://2000.dilum.io/*",
    "https://audiofilms-api.dilum.io/*",
    "http://localhost:*/*",
    "http://127.0.0.1:*/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/shadow.css"
      ],
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*"
      ]
    }
  ]
}
