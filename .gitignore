.DS_Store

# Local subtitle/video caches are disposable artifacts.
.subtitle-cache/
.video-info-cache/
app/.subtitle-source-shootout-cache/

# Local smoke screenshots and diagnostics are generated evidence, not source.
extensions/youtube-shadowing/.smoke-artifacts/

# Expert-review archives are generated on demand from tracked docs/source/screenshots.
docs/design-handoff/youtube-extension-expert-review/*.zip
