# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored and stays local.

# ===============================================
# SUBTITLE PROVIDER CONFIGURATION
# ===============================================
# Runtime default: `yt-dlp`
# Use Supadata only when you intentionally want the paid API fallback path.
SUBTITLE_PROVIDER=yt-dlp

# Required only when `SUBTITLE_PROVIDER=supadata`
# Get your API key from: https://supadata.ai/dashboard
SUPADATA_API_KEY=your_supadata_api_key_here

# Optional local provider configuration
# Only needed when the binary is not auto-detected.
# YT_DLP_PATH=/usr/bin/yt-dlp

# ===============================================
# DICTIONARY PROVIDER CONFIGURATION
# ===============================================
# Runtime default: `openrouter`
# Supported providers: `2000nl`, `openrouter`, `openai`, `free-dictionary`
DICTIONARY_PROVIDER=openrouter

# 2000NL platform dictionary provider
# Uses the production 2000NL Platform API by default.
# For production extension traffic, authenticated lookup/action/translation
# should use the forwarded 2000NL Connect Bearer token from the extension.
# Production guest lookup must use the dedicated public catalog endpoint and token.
# /api/health reports dictionary.guestLookup.productionReady=true only when
# DICTIONARY_2000NL_CATALOG_ACCESS_TOKEN is configured for DICTIONARY_PROVIDER=2000nl.
# DICTIONARY_2000NL_ACCESS_TOKEN is a short-lived local dogfood fallback only;
# it is never production-ready and is ignored for guest lookup in NODE_ENV=production.
# Do not configure a shared end-user token as production guest identity.
# DICTIONARY_PROVIDER=2000nl
# DICTIONARY_2000NL_API_BASE=https://2000.dilum.io/api/platform/v1
# DICTIONARY_2000NL_CATALOG_ACCESS_TOKEN=your_2000nl_catalog_lookup_token_here
# Optional private local fallback only:
# DICTIONARY_2000NL_ACCESS_TOKEN=your_short_lived_local_dogfood_token_here
# DICTIONARY_2000NL_LOCAL_DOGFOOD_GUEST_LOOKUP=false
# DICTIONARY_2000NL_TIMEOUT_MS=8000

# OpenAI dictionary provider
# Standard OpenAI:
# OPENAI_API_KEY=your_openai_api_key_here
# Optional override (defaults to https://api.openai.com/v1/chat/completions)
# OPENAI_API_URL=https://api.openai.com/v1/chat/completions
# OPENAI_MODEL=gpt-5.2
# OPENAI_DICTIONARY_PROMPT=Define the word "{{word}}" in "{{sourceLanguage}}" ...
#
# Azure OpenAI:
# If AZURE_OPENAI_ENDPOINT + AZURE_OPENAI_API_KEY are set, the OpenAI dictionary provider
# will use them automatically.
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=your_azure_openai_key
# AZURE_OPENAI_DEPLOYMENT=gpt-5.2
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Required for the default dictionary provider (`openrouter`)
# Get your API key from: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Default dictionary model:
# `x-ai/grok-4.1-fast:free`
# Verify current availability before changing it:
# https://openrouter.ai/models?q=x-ai
OPENROUTER_DICTIONARY_MODEL=x-ai/grok-4.1-fast:free

# Optional custom prompt template
# Available placeholders: {{word}}, {{sourceLanguage}}, {{context}}
# OPENROUTER_DICTIONARY_PROMPT=Define the word "{{word}}" in "{{sourceLanguage}}" using a style similar to a monolingual dictionary for language learners. Context: "{{context}}". Your answer should be brief, clear, and contain only the definition of target word "{{word}}". Avoid cognates or translations unless strictly necessary. If the word functions as a part of a phrase, idiom, or collocation, describe its meaning in that phrase as well, indicating both standalone and contextual meanings separately.

# Optional metadata for OpenRouter rankings
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com
# NEXT_PUBLIC_SITE_NAME=AudioFilms

# Public API base used when backend responses need absolute URLs, such as ASR
# job status/result links behind a reverse proxy.
# AUDIOFILMS_PUBLIC_API_BASE=https://audiofilms-api.dilum.io
# NEXT_PUBLIC_AUDIOFILMS_API_BASE=https://audiofilms-api.dilum.io

# ===============================================
# REMOTE BACKEND / EXTENSION API SURFACE
# ===============================================
# Public API base used by web consumers or extension packaging notes.
NEXT_PUBLIC_AUDIOFILMS_API_BASE=https://audiofilms-api.dilum.io

# Comma-separated CORS allowlists. Keep these explicit for tester builds.
ALLOWED_EXTENSION_ORIGINS=chrome-extension://hhdkchoccmikoefhenobdjipgdppdpoc
ALLOWED_WEB_ORIGINS=https://www.youtube.com,https://youtube.com

# Optional persistent cache/data roots for containers.
AUDIOFILMS_DATA_DIR=/data/audiofilms
AUDIOFILMS_CACHE_DIR=/data/audiofilms/cache
AUDIOFILMS_ASR_CACHE_DIR=/data/audiofilms/asr-cache

# Optional build metadata surfaced by /api/health.
# AUDIOFILMS_BUILD_VERSION=0.1.0
# AUDIOFILMS_BUILD_AT=2026-06-17T00:00:00Z
# AUDIOFILMS_COMMIT_SHA=...

# ===============================================
# ASR JOB API / WORKER CONFIGURATION
# ===============================================
# Keep disabled for public tester traffic until a worker and tester token are configured.
ASR_MODE=disabled
# Supported first deployment modes: disabled, file-queue, worker.
# file-queue/worker use ASR_QUEUE_DIR and ASR_ARTIFACT_STORE in this repo version.
ASR_QUEUE_DIR=/data/audiofilms/asr-jobs
ASR_ARTIFACT_STORE=file:///data/audiofilms/asr-artifacts
ASR_POLL_AFTER_MS=3000
ASR_MAX_ACTIVE_JOBS=1
ASR_MAX_DURATION_SEC=900
ASR_ALLOW_FULL_AUDIO=false

# Require a tester token for POST /api/asr/jobs unless explicitly disabled for private local dogfood.
ASR_AUTH_REQUIRED=true
ASR_TESTER_TOKENS=replace_with_random_long_token
ASR_RATE_LIMIT_MAX=4
ASR_RATE_LIMIT_WINDOW_MS=3600000

# Private compatibility endpoint. Production default should stay false.
LOCAL_ASR_PRACTICE_ENABLED=false

# ASR worker runtime defaults. The worker is optional and can run on another host
# if it can see the same queue/artifact store, or after the store is replaced.
ASR_WORKER_POLL_MS=3000
ASR_ENGINE=faster-whisper
ASR_MODEL=mobiuslabsgmbh/faster-whisper-large-v3-turbo
ASR_DEVICE=cpu
ASR_COMPUTE_TYPE=int8
